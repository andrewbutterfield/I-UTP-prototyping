\renewenvironment{theindex}
               {\if@twocolumn
                  \@restonecolfalse
                \else
                  \@restonecoltrue
                \fi
                \columnseprule \z@
                \columnsep 35\p@
                \twocolumn[\@makeschapterhead{\indexname}]%
                \parindent\z@
                \parskip\z@ \@plus .3\p@\relax
                \let\item\@idxitem}
               {\if@restonecol\onecolumn\else\clearpage\fi}

\renewcommand\@idxitem{\par\hangindent 40\p@}
\renewcommand\subitem{\par\hangindent 40\p@ \hspace*{20\p@}}
\renewcommand\subsubitem{\par\hangindent 40\p@ \hspace*{30\p@}}
\renewcommand\indexspace{\par \vskip 10\p@ \@plus5\p@ \@minus3\p@\relax}

\def\schemaindex#1{}

\def\notation#1{}

\def\makenotation{%
  \newwrite\@notationfile
  \immediate\openout\@notationfile=\jobname.idn
  \def\notation{\@bsphack\begingroup \@sanitize
    \@wrnotation}\typeout
  {Writing notation file \jobname.idn}%
  }

\def\@wrnotation#1{%
   \protected@write\@notationfile{}%
      {\string\indexentry{#1}{\thepage}}%
 \endgroup
 \@esphack
}

