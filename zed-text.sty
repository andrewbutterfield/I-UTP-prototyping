\def\ps@exercises{\let\@mkboth\@gobbletwo
  \def\@oddhead{\hbox{}{\normalfont\small\slshape\rightmark} \hfil
    {\normalfont\small\rmfamily\thepage}}%
  \def\@oddfoot{}%
  \def\@evenhead{{\normalfont\small\rmfamily\thepage\relax} \hfil
    {\normalfont\small\slshape\leftmark\hbox{}}}
  \def\@evenfoot{}%
  \def\chaptermark##1{}%
  \def\sectionmark##1{}%
  \def\subsectionmark##1{}}

\newtheorem{exercise}{Exercise}[chapter] %
\newtheorem{solution}{Solution}[chapter] %
\newtheorem{question}{Question}
\newtheorem{answer}{Answer}
\newcounter{more} \setcounter{more}{0}

\def\exercises#1#2{%
  \pagestyle{exercises}
  \def\@chapapp{Exercises for Chapter}
  \setcounter{chapter}{#1}
  \addtocounter{chapter}{-1}
  \chapter{#2}%
  \setcounter{page}{1}
  \markboth{Exercises}{\thechapter\headbreak#2}
  \@enumdepth=1
  }

\def\assignment#1#2{%
  \pagestyle{exercises}
  \def\@chapapp{#2}
  \def\thechapter{}
  \chapter{#1}%
  \setcounter{page}{1}
  \markboth{#2}{#1}
  \@enumdepth=1
  }

\def\moreExercises#1#2{%
  \pagestyle{exercises}
  \def\@chapapp{More Exercises for Chapter}
  \setcounter{more}{\value{exercise}}
  \setcounter{chapter}{#1}
  \addtocounter{chapter}{-1}
  \chapter{#2}%
  \setcounter{exercise}{more}
  \setcounter{page}{1}
  \markboth{More Exercises for Using Z}{\thechapter\headbreak#2}
  \@enumdepth=1
  }

\def\rules#1#2{%
  \pagestyle{exercises}
  \def\@chapapp{Rules for Chapter}
  \setcounter{chapter}{#1}
  \addtocounter{chapter}{-1}
  \chapter{#2}%
  \setcounter{page}{1}
  \markboth{Rules}{\thechapter\headbreak#2}
  \@enumdepth=1
  }

\def\solutions#1#2{%
  \pagestyle{exercises}
  \def\@chapapp{Solutions for Chapter}
  \setcounter{chapter}{#1}
  \addtocounter{chapter}{-1}
  \chapter{#2}%
  \setcounter{page}{1}
  \markboth{Solutions}{\thechapter\headbreak#2}
  \@enumdepth=1
  }

\def\moreSolutions#1#2{%
  \pagestyle{exercises}
  \def\@chapapp{More Solutions for Chapter}
  \setcounter{chapter}{#1}
  \addtocounter{chapter}{-1}
  \chapter{#2}%
  \setcounter{page}{1}
  \markboth{More Solutions for Using Z}{\thechapter\headbreak#2}
  \@enumdepth=1
  }

