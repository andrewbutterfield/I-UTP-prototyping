\def\cref#1{Chapter~\ref{chapter:#1}}
\def\sref#1{Section~\ref{section:#1}}
\def\tref#1{Table~\ref{table:#1}}
\def\xref#1{Example~\ref{example:#1}}
\def\lref#1{Law~\ref{law:#1}}
\def\aref#1{Appendix~\ref{appendix:#1}}

